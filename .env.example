# ---------------------------------------------------------------------------
# AI GitHub PR Reviewer — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# App environment: development | production
APP_ENV=development
LOG_LEVEL=INFO

# --- Database -------------------------------------------------------------
# Local (SQLite):    sqlite:///./ai_reviewer.db
# Docker (Postgres): postgresql+psycopg://reviewer:reviewer@db:5432/reviewer
DATABASE_URL=sqlite:///./ai_reviewer.db

# --- LLM provider ---------------------------------------------------------
# provider: openai | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- GitHub App (webhook bot) --------------------------------------------
GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=change-me-to-a-random-string
# Provide the App private key either inline (PEM, newlines as \n) ...
GITHUB_APP_PRIVATE_KEY=
# ... or as a path to the downloaded .pem file:
GITHUB_APP_PRIVATE_KEY_PATH=

# --- GitHub Action / personal access token (read PRs, post comments) -----
# Used by the Action wrapper and for local/manual runs.
GITHUB_TOKEN=ghp_your_personal_access_token_here
